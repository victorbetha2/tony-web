# --- CONFIGURACIÓN DE CORREO (RESEND) ---

# Sustituye 're_tu_api_key_aqui' por la API Key real que obtienes en https://resend.com
RESEND_API_KEY=re_tu_api_key_aqui

# El correo electrónico donde recibirás los mensajes del formulario de contacto
CONTACT_EMAIL=info@t2bteam.net

# --- BASE DE DATOS (NEON) ---
# Connection string (p. ej. desde integración Vercel + Neon)
# Obligatoria en .env o .env.local (db:seed carga ambos archivos automáticamente)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# --- NEXTAUTH (portal admin) ---
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local: http://localhost:3000 — en Vercel suele inferirse
NEXTAUTH_URL=http://localhost:3000

# Opcional: contraseña del usuario admin al ejecutar npm run db:seed
# ADMIN_SEED_PASSWORD=tu_password_seguro

# --- reCAPTCHA v3 (formularios de contacto y leads) ---
# Crear en https://www.google.com/recaptcha/admin — tipo v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- OTRAS CONFIGURACIONES ---
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
